#!/usr/bin/env bash
#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --job-name=PT_QM9_RGC_Eval
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=18
#SBATCH --time=02:00:00
#SBATCH --output=./scripts/jobs/out/%x_%A.out

set -euo pipefail

module purge
module load 2025

# shellcheck disable=SC1091
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_job_common.sh"

resolve_repo_root
load_dotenv_if_present "$REPO_ROOT/.env"
setup_cluster_layout
ensure_uv
initialize_run_context "${RUN_NAME:-qm9-rgc-eval-${QM9_TARGET:-mu}-k${RGC_NUM_EXTRA_KERNELS:-2}}"
ensure_shared_env
stage_repo_snapshot
link_shared_env_into_stage
write_run_metadata
print_runtime_diagnostics
validate_cuda_runtime

require_env_var "QM9_DATA_DIR"
require_env_var "QM9_TEST_CKPT"
ensure_qm9_dataset_ready
ensure_qm9_stats_ready "${QM9_TARGET:-mu}"

QM9_CONFIG="${QM9_CONFIG:-configs/qm9_regr.yaml}"
QM9_TARGET="${QM9_TARGET:-mu}"
QM9_BATCH_SIZE="${QM9_BATCH_SIZE:-96}"
QM9_GPUS="${QM9_GPUS:-1}"
QM9_NUM_WORKERS="${QM9_NUM_WORKERS:-8}"
QM9_PRECISION="${QM9_PRECISION:-32}"
QM9_ENABLE_WANDB="${QM9_ENABLE_WANDB:-0}"
QM9_EXTRA_ARGS="${QM9_EXTRA_ARGS:-}"
QM9_TEST_CKPT="$(resolve_path "$QM9_TEST_CKPT")"

RGC_NUM_EXTRA_KERNELS="${RGC_NUM_EXTRA_KERNELS:-2}"
RGC_SCALE="${RGC_SCALE:-1.0}"
RGC_KERNEL_INIT="${RGC_KERNEL_INIT:-normal}"
RGC_MIXING_INIT="${RGC_MIXING_INIT:-zeros}"
RGC_MIXING_L1="${RGC_MIXING_L1:-0.0}"
RGC_MIXING_L2="${RGC_MIXING_L2:-0.0}"
RGC_KERNEL_L2="${RGC_KERNEL_L2:-0.0}"

require_file "$QM9_TEST_CKPT"

declare -a qm9_args=(
  "qm9_regr"
  "--config" "$QM9_CONFIG"
  "--data_dir" "$QM9_DATA_DIR"
  "--target" "$QM9_TARGET"
  "--batch_size" "$QM9_BATCH_SIZE"
  "--gpus" "$QM9_GPUS"
  "--num_workers" "$QM9_NUM_WORKERS"
  "--precision" "$QM9_PRECISION"
  "--test_ckpt" "$QM9_TEST_CKPT"
  "--model.relaxed_group_convolution.enabled" "true"
  "--model.relaxed_group_convolution.num_extra_kernels" "$RGC_NUM_EXTRA_KERNELS"
  "--model.relaxed_group_convolution.scale" "$RGC_SCALE"
  "--model.relaxed_group_convolution.kernel_init" "$RGC_KERNEL_INIT"
  "--model.relaxed_group_convolution.mixing_init" "$RGC_MIXING_INIT"
  "--model.relaxed_group_convolution.mixing_l1" "$RGC_MIXING_L1"
  "--model.relaxed_group_convolution.mixing_l2" "$RGC_MIXING_L2"
  "--model.relaxed_group_convolution.kernel_l2" "$RGC_KERNEL_L2"
)

if [[ "$QM9_ENABLE_WANDB" != "1" ]]; then
  qm9_args+=("--logging.enabled" "false")
fi

if [[ -n "$QM9_EXTRA_ARGS" ]]; then
  # shellcheck disable=SC2206
  extra_args=( $QM9_EXTRA_ARGS )
  qm9_args+=("${extra_args[@]}")
fi

(
  cd "$STAGED_REPO_ROOT"
  log "Launching QM9 relaxed-group-convolution evaluation run from $STAGED_REPO_ROOT"
  srun uv run --no-sync python meta_main.py "${qm9_args[@]}"
)
